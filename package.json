{
  "name": "rankland-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "test": "vitest run --config vitest.config.ts",
    "init": "pnpm i --frozen-lockfile",
    "gen:client-router": "node scripts/client-routes.gen.js",
    "dev:start": "cross-env NODE_ENV=development tsnd --respawn --rs --transpile-only -P src/server/tsconfig.json --unhandled-rejections=warn --inspect=127.0.0.1:9232 src/server/index.ts",
    "dev": "concurrently -r \"npm:dev:start\" \"npm:gen:client-router\"",
    "gen:proto": "pbjs -t static-module -w commonjs -r rankland_live_contest_client --force-long -o src/common/proto/rankland_live_contest.js src/common/shared/proto/rankland_live_contest/*.proto && pbts -o src/common/proto/rankland_live_contest.d.ts src/common/proto/rankland_live_contest.js",
    "db:migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d src/server/database/typeorm-cli-data-source.ts src/server/database/migrations/ContestEventSchema",
    "db:migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d src/server/database/typeorm-cli-data-source.ts",
    "build:client": "rimraf dist && vite-ssr build --ssr src/client/entry-server.ts",
    "build:server": "rimraf app && tsc -p src/server/tsconfig.json && copyfiles -u1 \"src/**/*.js\" app",
    "build": "npm run build:client && npm run build:server",
    "build:e2e": "node scripts/e2e-build.cjs",
    "test:e2e": "npm run build:e2e && playwright test",
    "start": "cross-env NODE_ENV=production node --unhandled-rejections=warn app/server/index.js",
    "deploy": "npm run start"
  },
  "keywords": [
    "fullstack",
    "bwcx",
    "vue3",
    "ssr",
    "vite",
    "rankland",
    "ranklist"
  ],
  "author": "bLue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algoux/rankland-web.git"
  },
  "dependencies": {
    "@algoux/standard-ranklist": "^0.3.13",
    "@algoux/standard-ranklist-convert-to": "^0.2.2",
    "@algoux/standard-ranklist-renderer-component-core": "^0.6.4",
    "@algoux/standard-ranklist-renderer-component-vue": "^0.6.5",
    "@algoux/standard-ranklist-utils": "^0.3.3",
    "@antv/g2": "5.0.13",
    "@koa/cors": "^5.0.0",
    "@vue/runtime-core": "^3.5.35",
    "@vue/server-renderer": "^3.5.35",
    "@vueuse/core": "^14.3.0",
    "@vueuse/head": "^0.7.5",
    "axios": "^0.26.1",
    "bwcx-api": "^1.0.1",
    "bwcx-api-client": "^1.0.1",
    "bwcx-client-vue": "^1.0.1",
    "bwcx-client-vue3": "^1.0.2",
    "bwcx-common": "^1.0.1",
    "bwcx-core": "^1.0.1",
    "bwcx-ljsm": "^1.0.3",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "copy-to-clipboard": "^3.3.3",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.4.0",
    "ioredis": "^5.8.2",
    "koa-connect": "^2.1.0",
    "koa-favicon": "^2.1.0",
    "koa-mount": "^4.0.0",
    "koa-static": "^5.0.0",
    "lodash": "^4.17.21",
    "long": "^4.0.0",
    "lucide-vue-next": "^1.0.0",
    "module-alias": "^2.2.2",
    "monaco-editor": "^0.55.1",
    "mysql2": "^3.22.3",
    "node-fetch": "^2.7.0",
    "nprogress": "0.2.0",
    "protobufjs": "^6.11.4",
    "punycode": "^2.3.1",
    "radix-vue": "^1.9.17",
    "reflect-metadata": "^0.2.2",
    "statuses": "^2.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-interface-checker": "^1.0.2",
    "tsx": "^4.22.4",
    "typeorm": "0.3.26",
    "urlcat-fork": "^2.0.5",
    "vite": "~4.5.14",
    "vite-ssr": "^0.17.2",
    "vue": "^3.5.35",
    "vue-class-component": "^8.0.0-rc.1",
    "vue-property-decorator": "^10.0.0-rc.3",
    "vue-router": "^4.0.14",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/eslint-parser": "^7.23.3",
    "@playwright/test": "^1.60.0",
    "@types/file-saver": "^2.0.5",
    "@types/koa-favicon": "^2.0.21",
    "@types/lodash": "^4.17.1",
    "@types/long": "^4.0.2",
    "@types/node": "^20.19.41",
    "@types/nprogress": "0.2.3",
    "@types/statuses": "^2.0.4",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/eslint-config-typescript": "^12.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^7.0.0",
    "copyfiles": "^2.4.1",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-alloy": "^4",
    "eslint-plugin-vue": "^9.19.2",
    "less": "^4.1.2",
    "postcss": "^8.5.15",
    "prettier": "^2.5.1",
    "rimraf": "^4",
    "tailwindcss": "3.4.18",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "~5.9.3",
    "vitest": "0.34.6",
    "vue-eslint-parser": "^9.3.2",
    "vue-tsc": "^3.3.3"
  },
  "engines": {
    "node": "^20.0.0",
    "pnpm": "^9.0.0"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "overrides": {
      "@rollup/plugin-replace": "5.0.7",
      "vite": "4.5.14"
    }
  }
}
